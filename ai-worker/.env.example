# ============================================================
# DILAB AI Worker — 환경 변수 (실제 값은 .env 에 채우기, .gitignore 됨)
# ============================================================

# ---------- Supabase ----------
SUPABASE_URL=https://mxofuzhfdthqpzhzctwd.supabase.co
# Supabase Dashboard → Settings → API → service_role secret 에서 복사
SUPABASE_SERVICE_ROLE_KEY=

# ---------- DeepSeek (LLM) ----------
# https://platform.deepseek.com 에서 발급. OpenAI 호환 API.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 모델 ID — dashboard 에서 확인. 일반적인 후보:
#   deepseek-chat       (V3 기반 general)
#   deepseek-reasoner   (R1 기반 reasoning)
#   v4 pro 등 신규 모델 ID 는 dashboard 표기 그대로 사용
LLM_MODEL=deepseek-chat

# ---------- 임베딩 모델 (자체 호스팅) ----------
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# ---------- Naver Open API (제품 자동 검색) ----------
# https://developers.naver.com/apps 에서 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ---------- 환경 ----------
ENVIRONMENT=development
LOG_LEVEL=info
