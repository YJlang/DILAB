# ============================================================
# DILAB prototype (Next.js) — 로컬 개발용 환경 변수
#
# 실제 값은 .env.local 에 채우기 (.gitignore 됨).
# production 의 환경 변수는 wrangler.jsonc 의 vars 블록이 source-of-truth.
# ============================================================

# ⚠️ NEXT_PUBLIC_ 접두사 절대 사용 X.
#    Next.js 가 build 시점에 값을 inline 한다 (DefinePlugin) →
#    Cloudflare Workers 의 runtime vars 가 적용되지 않음.
#    이 파일의 변수들은 모두 server-only (route handlers / SSR) 에서만 사용.

# ---------- Supabase (publishable / RLS 보호) ----------
SUPABASE_URL=https://mxofuzhfdthqpzhzctwd.supabase.co
# Supabase Dashboard → Settings → API → anon / publishable key
# (sb_publishable_... 또는 eyJhbGc... 형식 모두 OK)
SUPABASE_ANON_KEY=

# ---------- AI Worker ----------
# 로컬 개발: http://127.0.0.1:8000
# production (Workers): wrangler.jsonc 의 vars.AI_WORKER_URL 사용 (trycloudflare.com)
AI_WORKER_URL=http://127.0.0.1:8000
